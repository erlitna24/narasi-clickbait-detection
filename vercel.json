{
  "version": 2,
  "rewrites": [
    {
      "source": "/",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/index.html",
      "destination": "/frontend/index.html"
    },
    {
      "source": "/tentang",
      "destination": "/frontend/tentang.html"
    },
    {
      "source": "/tentang.html",
      "destination": "/frontend/tentang.html"
    },
    {
      "source": "/style.css",
      "destination": "/frontend/style.css"
    },
    {
      "source": "/script.js",
      "destination": "/frontend/script.js"
    }
  ]
}
